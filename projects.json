{
  "projects": {
    "langgraph-orchestrator": {
      "path": "~/projects/langgraph-orchestrator",
      "description": "ローカルAIエージェント基盤（LangGraph + Ollama）",
      "language": "python",
      "python_version": "3.11",
      "confidential": false,
      "model_override": null,
      "active": true,
      "tags": ["infra", "ai-agent"]
    },
    "langfuse": {
      "path": "~/projects/langfuse",
      "description": "Langfuse（Docker）- トレース・コスト可視化",
      "language": "docker",
      "confidential": false,
      "model_override": null,
      "active": true,
      "tags": ["infra", "observability"]
    }
  },
  "defaults": {
    "model": "qwen2.5-coder:14b",
    "model_debug": "deepseek-r1:14b",
    "model_fast": "gemini-2.5-flash",
    "model_local_fast": "qwen2.5-coder:7b",
    "model_confidential": "qwen2.5-coder:14b",
    "python_version": "3.11",
    "venv_name": ".venv",
    "debate_threshold": 7,
    "debate_enabled": true
  }
}
